# Release signing config for Genesyx. Copy this file to `keystore.properties` (which is gitignored)
# and fill in real values after generating your upload keystore:
#
#   keytool -genkeypair -v -keystore genesyx-release.jks \
#       -keyalg RSA -keysize 2048 -validity 10000 -alias genesyx
#
# Then back up genesyx-release.jks in TWO separate places. Losing it means you can never update
# the app on the Play Store.

storeFile=../genesyx-release.jks
storePassword=CHANGE_ME
keyAlias=genesyx
keyPassword=CHANGE_ME
