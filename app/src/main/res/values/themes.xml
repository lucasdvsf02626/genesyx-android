<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme. UI is Compose; this only backs the Activity before setContent. -->
    <style name="Theme.Genesyx" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash screen (androidx.core:core-splashscreen) -->
    <style name="Theme.Genesyx.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/zenith</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Genesyx</item>
    </style>
</resources>
